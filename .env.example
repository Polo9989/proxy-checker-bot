# ─── Telegram ───────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ─── Proxy Checker Defaults ─────────────────────────────
DEFAULT_TIMEOUT=10
DEFAULT_CONCURRENCY=500
DEFAULT_RETRIES=2
DEFAULT_TEST_URL=https://httpbin.org/ip
DEFAULT_MAX_WORKERS=1000

# ─── Limits ─────────────────────────────────────────────
MAX_PROXIES_PER_USER=100000
MAX_FILE_SIZE_MB=50

# ─── Database ───────────────────────────────────────────
DATABASE_PATH=./data/bot.db

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# ─── Output ─────────────────────────────────────────────
OUTPUT_DIR=./output
